    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/uuid": "^9.0.2",
    "eslint": "^8.43.0",
    "prettier": "^2.8.8",
    "tsx": "^3.14.0"
